{
    "firebaserc": {
        "projects": {
            "default": "YOUR_FIREBASE_PROJECT_ID"
        }
    },
    "firebase.json": {
        "hosting": {
            "public": "dist",
            "ignore": [
                "firebase.json",
                ".firebaserc",
                "**/.*",
                "**/node_modules/**"
            ],
            "rewrites": [
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ]
        }
    }
}